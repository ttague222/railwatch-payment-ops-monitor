{
  "buildCommand": "cd railwatch && npm install && npm run build",
  "outputDirectory": "railwatch/dist",
  "framework": "vite",
  "installCommand": "echo 'install handled in buildCommand'",
  "routes": [
    {
      "src": "/api/fred/(.*)",
      "dest": "https://api.stlouisfed.org/fred/$1"
    },
    {
      "src": "/api/marketaux/(.*)",
      "dest": "https://api.marketaux.com/$1"
    },
    {
      "src": "/api/frankfurter/(.*)",
      "dest": "https://api.frankfurter.dev/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
